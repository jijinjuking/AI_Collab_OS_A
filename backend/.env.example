# ============================================
# AI-Collab-OS Backend Configuration
# Copy to .env and fill in your values
# ============================================

# --- Application ---
APP_NAME=AI-Collab-OS
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/dev.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_collab

# Connection pool (PostgreSQL only)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# --- Default LLM ---
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_PROVIDER=openai

# --- File Storage ---
WORKSPACE_ROOT=./workspaces

# --- Docker Sandbox ---
SANDBOX_ENABLED=false
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY_LIMIT=512m

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USER=200
RATE_LIMIT_IP=60
RATE_LIMIT_WINDOW=60
