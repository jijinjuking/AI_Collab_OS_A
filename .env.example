# ============================================================
# AI-Collab-OS Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=AI-Collab-OS
APP_ENV=production
DEBUG=false
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL for production) ---
DATABASE_URL=postgresql+asyncpg://collab:password@postgres:5432/ai_collab
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# --- JWT ---
JWT_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM Providers ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_PROVIDER=openai

# --- File Storage ---
WORKSPACE_ROOT=/app/workspaces

# --- Docker Sandbox ---
SANDBOX_ENABLED=false
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY_LIMIT=512m

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USER=200
RATE_LIMIT_IP=60
RATE_LIMIT_WINDOW=60
